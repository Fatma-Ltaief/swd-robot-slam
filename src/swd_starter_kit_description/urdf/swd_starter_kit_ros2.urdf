<?xml version="1.0"?>
<robot name="swd_starter_kit">

  <!-- ========= GLOBAL MATERIALS ========= -->
  <material name="body_dark_grey">
    <color rgba="0.20 0.20 0.22 1.0"/>
  </material>

  <material name="body_light_grey">
    <color rgba="0.70 0.70 0.72 1.0"/>
  </material>

  <material name="wheel_orange">
    <color rgba="0.90 0.55 0.15 1.0"/>
  </material>

  <material name="sensor_yellow">
    <color rgba="0.95 0.80 0.20 1.0"/>
  </material>

  <material name="sensor_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <material name="caster_white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>

  <material name="acrylic_clear">
    <color rgba="0.95 0.95 0.95 0.25"/>
  </material>

  <!-- ========= BASE FOOTPRINT ========= -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========= BASE LINK ========= -->
<link name="base_link">
  <visual>
    <origin xyz="-0.46 -0.27 0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file:///home/fatma/ws_ros2/src/swd_starter_kit_description/meshes/starter_kit_base.stl"
            scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="body_light_grey"/>
  </visual>

  <visual>
    <origin xyz="-0.46 -0.27 0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file:///home/fatma/ws_ros2/src/swd_starter_kit_description/meshes/starter_kit.stl"
            scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="body_dark_grey"/>
  </visual>

  <visual>
    <origin xyz="-0.05 0 0.18" rpy="0 0 0"/>
    <geometry>
      <box size="0.55 0.40 0.01"/>
    </geometry>
    <material name="acrylic_clear"/>
  </visual>

  <collision>
    <origin xyz="-0.05 0 0.10" rpy="0 0 0"/>
    <geometry>
      <box size="0.55 0.40 0.20"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="-0.05 0 0.10" rpy="0 0 0"/>
    <mass value="27.0"/>
    <inertia ixx="0.70673" ixy="0.0" ixz="0.0"
             iyy="0.70673" iyz="0.0"
             izz="1.31220"/>
  </inertial>
</link>

  <!-- ========= LEFT DRIVE WHEEL ========= -->
  <joint name="base_swd_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="swd_left_link"/>
    <origin xyz="0.0 0.25 0.08" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="swd_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="file:///home/fatma/ws_ros2/src/swd_starter_kit_description/meshes/wheels/starter_kit_left_tire.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.037" radius="0.063"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00111" ixy="0.0" ixz="0.0"
               iyy="0.00111" iyz="0.0"
               izz="0.00198"/>
    </inertial>
  </link>

  <!-- ========= RIGHT DRIVE WHEEL ========= -->
  <joint name="base_swd_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="swd_right_link"/>
    <origin xyz="0.0 -0.25 0.08" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="swd_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="file:///home/fatma/ws_ros2/src/swd_starter_kit_description/meshes/wheels/starter_kit_right_tire.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.037" radius="0.063"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00111" ixy="0.0" ixz="0.0"
               iyy="0.00111" iyz="0.0"
               izz="0.00198"/>
    </inertial>
  </link>

  <!-- ========= REAR CASTERS ========= -->
  <joint name="caster_back_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_right_link"/>
    <origin xyz="-0.35 -0.17 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_right_link">
    <visual>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.013"/>
      </geometry>
      <material name="caster_white"/>
    </visual>

    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_back_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_left_link"/>
    <origin xyz="-0.35 0.17 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_left_link">
    <visual>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.013"/>
      </geometry>
      <material name="caster_white"/>
    </visual>

    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- ========= LIDAR ========= -->
  <joint name="base_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.05 0 0.2" rpy="0 0 0"/>
  </joint>

  <link name="laser">
    <visual>
      <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.045"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.055"/>
      </geometry>
      <material name="sensor_yellow"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.055"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- ========= CAMERA ========= -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="-0.05 0 0.3" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.073 0.276 0.072"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>

    <collision>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.073 0.276 0.072"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

</robot>